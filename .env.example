# Copy to .env and fill in. The engine reads these via os.environ — there are
# no hardcoded keys anywhere in the codebase.

# Required for live LLM calls. Without it, NPCs return "wait" and the engine
# still ticks (useful for testing rules/maps).
KEROS_API_KEY=

# Optional. Any OpenAI-compatible base URL. Defaults to OpenRouter.
KEROS_API_BASE=https://openrouter.ai/api/v1

# Optional. Comma-separated list of model IDs used for round-robin whenever a
# caller passes a model containing ":free". Leave empty to disable rotation.
KEROS_FREE_MODELS=

# Optional defaults for scripts/live.py.
KEROS_MODEL_NPC=openai/gpt-4o-mini
KEROS_MODEL_GM=openai/gpt-4o-mini
